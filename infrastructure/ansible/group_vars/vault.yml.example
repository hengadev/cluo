---
# CLUO - Encrypted Secrets
# This file should be encrypted with ansible-vault
#
# Usage:
#   1. Copy this file: cp vault.yml.example vault.yml
#   2. Fill in your secrets
#   3. Encrypt: ansible-vault encrypt vault.yml
#   4. Run playbook: ansible-playbook site.yml --ask-vault-pass

# Database secrets
postgres_password: "your_secure_postgres_password_here"
redis_password: "your_secure_redis_password_here"

# Application secrets
jwt_secret: "your_jwt_secret_at_least_32_chars_long"
session_secret: "your_session_secret_at_least_32_chars_long"

# AWS credentials (for S3)
aws_access_key_id: "AKIAIOSFODNN7EXAMPLE"
aws_secret_access_key: "wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"

# Other secrets
oauth_client_secret: ""  # If using OAuth
api_encryption_key: ""   # For encrypting sensitive data in database

# Backup credentials (if using separate AWS account for backups)
backup_aws_access_key_id: ""
backup_aws_secret_access_key: ""

# Monitoring credentials (if using external monitoring)
monitoring_api_key: ""
monitoring_webhook_url: ""
