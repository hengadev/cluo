---
# CLUO - Encrypted Secrets
# This file should be encrypted with ansible-vault
#
# Usage:
#   1. Copy this file: cp vault.yml.example vault.yml
#   2. Fill in your secrets
#   3. Encrypt: ansible-vault encrypt vault.yml
#   4. Run playbook: ansible-playbook site.yml --ask-vault-pass

# PostgreSQL passwords
cluo_prod_db_password: "your_secure_prod_postgres_password_here"
cluo_staging_db_password: "your_secure_staging_postgres_password_here"

# MinIO (S3-compatible object storage)
minio_root_user: "your_minio_root_user"
minio_root_password: "your_minio_root_password"

# HashiCorp Vault root token (transit encryption + pepper secrets)
vault_root_token: "your_vault_root_token"

# Cluo backup (MinIO data -> S3, GPG-encrypted)
cluo_backup_aws_access_key_id: "AKIAIOSFODNN7EXAMPLE"
cluo_backup_aws_secret_access_key: "wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
cluo_backup_passphrase: "your_gpg_symmetric_passphrase"

# UptimeRobot (optional)
uptimerobot_api_key: ""
