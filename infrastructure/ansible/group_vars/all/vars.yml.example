---
# CLUO - Common Variables for All Hosts
# Copy this to group_vars/all.yml and customize
#
# Variable names mirror homelab/ansible's real deployment vars (see
# homelab/Makefile's ANSIBLE_VARS and homelab/ansible/deploy.yml) since this
# is the same app and the same compose files, just deployed to its own VPS
# instead of homelab's shared one.

# Application settings
app_name: cluo
app_user: deploy
app_group: deploy
app_dir: /opt/cluo

# Swap file (system_hardening role) — needed headroom on an 8GB cpx31 once
# Ollama + whisper.cpp run alongside Postgres/Redis/MinIO/app containers
swap_file_path: /swapfile
swap_file_size: 4G

# Domain
cluo_domain: clientvault.fr
production_api_domain: api.clientvault.fr

# Caddy (reverse proxy, runs as a container in the prod compose project)
caddy_data_dir: "{{ app_dir }}/caddy"
caddy_cloudflare_api_token: "{{ vault_caddy_cloudflare_api_token | default('') }}"

# Docker image registry + tags
cluo_registry: hengadev
cluo_prod_tag: latest
cluo_staging_tag: latest

# PostgreSQL (single cluo-prod-postgres container; staging gets its own
# role + database on the same container, created by app_deploy)
cluo_prod_db_name: cluo_production
cluo_prod_db_user: cluo
# cluo_prod_db_password: Use vault (see vault.yml.example)
cluo_staging_db_name: cluo_staging
cluo_staging_db_user: cluo_staging
# cluo_staging_db_password: Use vault (see vault.yml.example)

# AWS region (matches infrastructure/terraform's aws_region) — used by the
# self-hosted Vault container's S3 storage backend / KMS auto-unseal
aws_region: eu-central-1

# MinIO (S3-compatible object storage, self-hosted in the cluo-prod-minio
# container, shared by prod + staging)
# minio_root_user / minio_root_password / minio_kms_secret_key: Use vault (see vault.yml.example)

# HashiCorp Vault (self-hosted in the cluo-prod-vault container; S3 storage
# backend + AWS KMS auto-unseal, see infrastructure/terraform/vault.tf)
# vault_kms_key_id / vault_s3_bucket / vault_access_key_id / vault_secret_access_key:
#   fill in from `terraform output` after `terraform apply` (see vault.yml.example)
# vault_root_token: only exists after `vault operator init` is run against the
#   live container — see infrastructure/DEPLOY_RUNBOOK.md

# Cluo backup (MinIO data -> S3, GPG-encrypted, runs from the
# cluo-staging-backup container; backs up the single shared MinIO instance
# using production's backup IAM user/bucket, per the "one shared backup
# container" decision — the staging backup IAM user/bucket terraform also
# creates is intentionally unused)
cluo_backup_aws_region: eu-central-1
cluo_backup_s3_bucket: cluo-postgres-backups-production-k4xpqz
# cluo_backup_aws_access_key_id / cluo_backup_aws_secret_access_key: fill in from
#   `terraform output backup_production_access_key_id/backup_production_secret_access_key`
# cluo_backup_passphrase: Use vault

# AI stack (Ollama + whisper.cpp) — one shared cluo-prod-ollama container for
# both prod and staging; whisper.cpp runs in-process inside the cluo-api image
cluo_ai_ollama_enabled: true
cluo_ai_ollama_model: llama3.2
cluo_ai_whisper_enabled: true
cluo_ai_whisper_model: base
cluo_ai_whisper_language: fr

# Security settings
ssh_port: 22
# List of IPs allowed to SSH (0.0.0.0/0 for any)
allowed_ssh_ips:
  - "0.0.0.0/0"

# Cloudflare IPs (for firewall)
# Get from: https://www.cloudflare.com/ips-v4
cloudflare_ips:
  - "173.245.48.0/20"
  - "103.21.244.0/22"
  - "103.22.200.0/22"
  - "103.31.4.0/22"
  - "141.101.64.0/18"
  - "108.162.192.0/18"
  - "190.93.240.0/20"
  - "188.114.96.0/20"
  - "197.234.240.0/22"
  - "198.41.128.0/17"
  - "162.158.0.0/15"
  - "104.16.0.0/13"
  - "104.24.0.0/14"
  - "172.64.0.0/13"
  - "131.0.72.0/22"

# Security features
enable_fail2ban: true
enable_automatic_updates: true

# Monitoring (optional, disabled by default — not part of the real
# homelab deployment, opt-in scaffolding for the new VPS)
enable_monitoring: false
enable_loki: false

# Uptime monitoring (optional, disabled by default — UptimeRobot, not
# part of the real homelab deployment)
enable_uptime_monitoring: false
# uptimerobot_api_key: ""
uptimerobot_monitor_interval: 300
uptimerobot_monitor_friendly_name: "Cluo API /health"

# Admin notifications
admin_email: henry.gary@hotmail.com

# Public SSH keys for the deploy user
# ssh_public_keys: |
#   ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIExample user@host
