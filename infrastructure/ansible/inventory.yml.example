# =============================================================================
# Cluo Infrastructure Inventory Example
# =============================================================================
#
# Usage:
#   1. Copy this file to inventory.yml:
#      cp inventory.yml.example inventory.yml
#   2. Fill in the values from your Terraform outputs
#   3. DO NOT commit inventory.yml to git (contains sensitive data)
#
# Getting Terraform outputs:
#   cd infrastructure/terraform
#   terraform output -json > outputs.json
#
# =============================================================================

all:
  vars:
    # --------------------------------------------------------------------------
    # Application Settings
    # --------------------------------------------------------------------------
    app_name: cluo
    app_user: deploy
    app_group: deploy
    app_dir: /opt/cluo

    # --------------------------------------------------------------------------
    # Domain Settings (from Terraform)
    # --------------------------------------------------------------------------
    cluo_domain: clientvault.fr
    production_api_domain: api.clientvault.fr

    # --------------------------------------------------------------------------
    # Docker image registry + tags
    # --------------------------------------------------------------------------
    cluo_registry: henga
    cluo_prod_tag: latest
    cluo_staging_tag: staging

    # --------------------------------------------------------------------------
    # PostgreSQL (single cluo-prod-postgres container; staging gets its own
    # role + database on the same container, created by app_deploy)
    # --------------------------------------------------------------------------
    cluo_prod_db_name: cluo_production
    cluo_prod_db_user: cluo
    cluo_prod_db_password: "your_secure_prod_postgres_password_here"
    cluo_staging_db_name: cluo_staging
    cluo_staging_db_user: cluo_staging
    cluo_staging_db_password: "your_secure_staging_postgres_password_here"

    # --------------------------------------------------------------------------
    # MinIO (S3-compatible object storage, shared by prod + staging)
    # --------------------------------------------------------------------------
    minio_root_user: "your_minio_root_user"
    minio_root_password: "your_minio_root_password"

    # --------------------------------------------------------------------------
    # HashiCorp Vault (transit encryption key + pepper secret per environment)
    # --------------------------------------------------------------------------
    vault_root_token: "your_vault_root_token"

    # --------------------------------------------------------------------------
    # Cluo backup (MinIO data -> S3, GPG-encrypted, runs from the
    # cluo-staging-backup container)
    # --------------------------------------------------------------------------
    cluo_backup_aws_access_key_id: "AKIAIOSFODNN7EXAMPLE"
    cluo_backup_aws_secret_access_key: "wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
    cluo_backup_aws_region: eu-central-1
    cluo_backup_s3_bucket: cluo-backups
    cluo_backup_passphrase: "your_gpg_symmetric_passphrase"

    # --------------------------------------------------------------------------
    # SSH Keys for the deploy user
    # --------------------------------------------------------------------------
    ssh_public_keys: |
      ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIEXAMPLE your_email@example.com

    # --------------------------------------------------------------------------
    # Security Settings
    # --------------------------------------------------------------------------
    enable_fail2ban: true
    enable_automatic_updates: true
    ssh_port: 22
    allowed_ssh_ips:
      - "0.0.0.0/0"

    # --------------------------------------------------------------------------
    # Monitoring (optional, disabled by default)
    # --------------------------------------------------------------------------
    enable_monitoring: false
    enable_loki: false

    # --------------------------------------------------------------------------
    # Uptime monitoring (optional, disabled by default)
    # --------------------------------------------------------------------------
    enable_uptime_monitoring: false
    uptimerobot_api_key: ""
    uptimerobot_monitor_interval: 300
    uptimerobot_monitor_friendly_name: "Cluo API /health"

    # --------------------------------------------------------------------------
    # Email for notifications
    # --------------------------------------------------------------------------
    admin_email: henry.gary@hotmail.com

  children:
    webservers:
      hosts:
        cluo-vps:
          # Get this from Terraform output: server_ipv4
          ansible_host: "your_server_ip_here"  # From Terraform output
          ansible_user: root
          # Path to your SSH key (the one configured in Hetzner Cloud)
          ansible_private_key_file: ~/.ssh/cluo  # Or your SSH key path
