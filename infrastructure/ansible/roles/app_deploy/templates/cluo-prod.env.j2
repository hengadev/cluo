# Cluo Production Environment
# Generated by Ansible — do not edit manually

# Image registry (used by docker-compose to pull cluo images)
CLUO_REGISTRY={{ cluo_registry }}
CLUO_PROD_TAG={{ cluo_prod_tag }}

# Caddy (reverse proxy, runs as a container in this compose project)
CADDY_DATA_DIR={{ caddy_data_dir }}
CLOUDFLARE_API_TOKEN={{ caddy_cloudflare_api_token }}

# MinIO (runs as a container in this compose project)
MINIO_ROOT_USER={{ minio_root_user }}
MINIO_ROOT_PASSWORD={{ minio_root_password }}
MINIO_KMS_SECRET_KEY={{ minio_kms_secret_key }}

# HashiCorp Vault (runs as a container in this compose project; S3 storage
# backend + AWS KMS auto-unseal — see infrastructure/terraform/vault.tf.
# These three come from `terraform output` after apply.)
VAULT_CONFIG_DIR={{ app_dir }}/vault/config
VAULT_AWS_ACCESS_KEY_ID={{ vault_access_key_id | default('') }}
VAULT_AWS_SECRET_ACCESS_KEY={{ vault_secret_access_key | default('') }}
VAULT_AWS_REGION={{ aws_region | default('eu-central-1') }}

# Runtime
CLUO_ENVIRONMENT=production
CLUO_SERVER_HOST=0.0.0.0
CLUO_SERVER_PORT=8080
CLUO_SERVER_READ_TIMEOUT=15s
CLUO_SERVER_WRITE_TIMEOUT=15s
CLUO_SERVER_IDLE_TIMEOUT=60s
CLUO_SERVER_SHUTDOWN_TIMEOUT=30s

# Database (connects to cluo-prod-postgres container)
CLUO_DB_HOST=cluo-prod-postgres
CLUO_DB_PORT=5432
CLUO_DB_NAME={{ cluo_prod_db_name }}
CLUO_DB_USER={{ cluo_prod_db_user }}
CLUO_DB_PASSWORD={{ cluo_prod_db_password }}
CLUO_DB_SSL_MODE=disable
CLUO_DB_MAX_OPEN_CONNS=25
CLUO_DB_MAX_IDLE_CONNS=5
CLUO_DB_CONN_MAX_LIFETIME=5m
CLUO_DB_CONN_MAX_IDLE_TIME=1m

# Redis (connects to cluo-prod-redis container)
CLUO_REDIS_HOST=cluo-prod-redis
CLUO_REDIS_PORT=6379
CLUO_REDIS_PASSWORD=
CLUO_REDIS_DB=0

# HashiCorp Vault (connects to the cluo-prod-vault container, self-hosted
# on this VPS — vault_root_token only exists after `vault operator init`
# has been run against the live container; see infrastructure/DEPLOY_RUNBOOK.md)
VAULT_ADDR=http://cluo-prod-vault:8200
VAULT_TOKEN={{ vault_root_token | default('') }}
CLUO_VAULT_MOUNT_PATH=secret
CLUO_VAULT_TRANSIT_MOUNT_PATH=transit
CLUO_VAULT_KEY_NAME=cluo-prod
CLUO_VAULT_PEPPER_PATH=secret/cluo/prod/pepper

# Logging
CLUO_LOG_LEVEL=info
CLUO_LOG_STYLE=json

# Metrics
CLUO_METRICS_ENABLED=true
CLUO_METRICS_PATH=/metrics

# Tracing (disabled by default — enable when OTLP endpoint is available)
CLUO_TRACING_ENABLED=false
CLUO_TRACING_SAMPLER=0.1

# Service identification
CLUO_SERVICE_NAME=cluo-api
CLUO_SERVICE_VERSION=0.1.0

# CORS allowed origins (comma-separated list)
# "wails://wails" is required for Wails desktop production builds; the web and
# mobile origins are needed because each is its own Caddy vhost proxying
# straight to its own container, so /auth/* calls are genuinely cross-origin
CLUO_CORS_ORIGIN=wails://wails,https://wails.localhost,https://{{ cluo_domain }},https://www.{{ cluo_domain }},https://mobile.{{ cluo_domain }}

# SvelteKit frontend: public API URL consumed by web and mobile apps at runtime
PUBLIC_API_URL=https://api.{{ cluo_domain }}

# S3-compatible object storage (self-hosted cluo-prod-minio container)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID={{ minio_root_user }}
AWS_SECRET_ACCESS_KEY={{ minio_root_password }}
CLUO_S3_ENDPOINT=http://cluo-prod-minio:9000
CLUO_S3_BUCKET_NAME=cluo-prod
CLUO_S3_BASE_URL=https://media.{{ cluo_domain }}/cluo-prod

# Ollama (local LLM, shared sibling container — cluo-prod-ollama)
CLUO_AI_OLLAMA_ENABLED={{ cluo_ai_ollama_enabled | default(true) | lower }}
CLUO_AI_OLLAMA_BASE_URL=http://cluo-prod-ollama:11434
CLUO_AI_OLLAMA_MODEL={{ cluo_ai_ollama_model | default('llama3.2') }}

# Whisper.cpp (local speech-to-text, baked into the cluo-api image)
CLUO_AI_WHISPER_ENABLED={{ cluo_ai_whisper_enabled | default(true) | lower }}
CLUO_AI_WHISPER_BINARY=/usr/local/bin/whisper
CLUO_AI_WHISPER_MODEL_PATH=/models/whisper
CLUO_AI_WHISPER_MODEL={{ cluo_ai_whisper_model | default('base') }}
CLUO_AI_WHISPER_LANGUAGE={{ cluo_ai_whisper_language | default('fr') }}
