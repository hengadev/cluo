#cloud-config
# Minimal cloud-init for the Cluo VPS
# Only ensures the server is reachable by Ansible — all configuration
# (user creation, Docker, firewall, fail2ban, Caddy, the app, etc.) is
# handled by Ansible (see infrastructure/ansible/site.yml).

package_update: true
package_upgrade: true

packages:
  - python3
  - python3-apt

final_message: "Cloud-init complete. Server is ready for Ansible provisioning."
