# Copy this file to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to git (it contains sensitive data)

# Project settings
project_name = "cluo"
environment  = "dev"
domain_name  = "yourdomain.com"  # Your root domain in Cloudflare

# Hetzner settings
hetzner_token         = "your_hetzner_api_token"
hetzner_server_type   = "cpx11"  # 2 vCPU, 2 GB RAM - adjust as needed
hetzner_server_location = "nbg1" # Nuremberg - choose: nbg1, fsn1, hel1, ash
hetzner_ssh_keys      = ["your-ssh-key-name"]  # SSH key names in Hetzner

# Cloudflare settings
cloudflare_api_token  = "your_cloudflare_api_token"  # Zone:Edit + DNS:Edit permissions
cloudflare_zone_id    = "your_cloudflare_zone_id"

# AWS settings
aws_region            = "eu-central-1"  # Frankfurt - closest to Hetzner Nuremberg
