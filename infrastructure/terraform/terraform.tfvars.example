# =============================================================================
# Cluo Terraform Configuration Example
# Single VPS Architecture: Staging + Production on one server
# =============================================================================

# -----------------------------------------------------------------------------
# Usage Instructions
# -----------------------------------------------------------------------------
#
# 1. Copy this file to terraform.tfvars:
#    cp terraform.tfvars.example terraform.tfvars
#
# 2. Fill in all required values below
#
# 3. DO NOT commit terraform.tfvars to git (it contains sensitive data)
#
# 4. AWS Profile: This configuration uses the "terraform-cluo" AWS profile.
#    Make sure you have it configured:
#    aws configure --profile terraform-cluo
#
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Core Settings
# -----------------------------------------------------------------------------

project_name = "cluo"
domain_name  = "clientvault.fr"
aws_region   = "eu-central-1"

# -----------------------------------------------------------------------------
# Hetzner Cloud Settings
# -----------------------------------------------------------------------------

# Get your token at: https://console.hetzner.cloud → Security → API Tokens
# Required permissions: Read & Write
hcloud_token    = "your_hetzner_api_token_here"

# Server type: cpx31 recommended (8GB RAM for both environments)
# See: https://www.hetzner.com/cloud#pricing
server_type     = "cpx31"  # 4 vCPU, 8 GB RAM, 160 GB SSD
server_location = "nbg1"   # Nuremberg (options: nbg1, fsn1, hel1, ash, sin, hil)
server_image    = "ubuntu-24.04"

# SSH key: Must be pre-created in Hetzner Cloud Console
# 1. Go to https://console.hetzner.cloud → Security → SSH Keys
# 2. Add your public key with name "terraform-cluo"
ssh_key_name    = "terraform-cluo"

# Enable automatic backups (additional 20% of server price)
enable_backups  = true

# -----------------------------------------------------------------------------
# Cloudflare Settings
# -----------------------------------------------------------------------------

# Get your token at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone - Read, DNS - Edit
cloudflare_token = "your_cloudflare_api_token_here"

# Zone ID: Found in Cloudflare Dashboard → Your Domain → Overview
zone_id       = "your_cloudflare_zone_id_for_clientvault_fr"

# Contact email for DMARC reports
contact_email = "admin@clientvault.fr"

# -----------------------------------------------------------------------------
# Database Settings (Single PostgreSQL Instance)
# -----------------------------------------------------------------------------
#
# The single VPS runs one PostgreSQL instance with two databases:
# - cluo_staging  (for staging environment)
# - cluo_production (for production environment)
#
# PostgreSQL will be deployed via Docker Compose on the VPS.

# PostgreSQL user password (shared for both databases)
# Generate a strong password for the 'cluo' PostgreSQL user
staging_db_password    = "your_strong_staging_db_password_here"
production_db_password = "your_strong_production_db_password_here"

# -----------------------------------------------------------------------------
# Email (SES) Settings
# -----------------------------------------------------------------------------

# DMARC policy: none, quarantine, or reject
email_dmarc_policy = "quarantine"

# Mail exchange servers for inbound email
mx_servers = [
  { server = "mx1.example.com", priority = 10 },
  { server = "mx2.example.com", priority = 20 }
]

# Mailbox provider DKIM records (optional, for email forwarding)
email_dkim_records = {
  # Example for Google Workspace:
  # "google1._domainkey" = {
  #   type    = "CNAME"
  #   content = "google1._domainkey.example.com"
  # }
  # "default1._domainkey" = {
  #   type    = "CNAME"
  #   content = "default1.dkim.example.com"
  # }
}

# =============================================================================
# Server Port Allocation
# =============================================================================
#
# Staging Environment (Ports 8000-8999):
#   staging-api.clientvault.fr    → 8080
#   staging.clientvault.fr        → 8100
#   staging-mobile.clientvault.fr → 8200
#
# Production Environment (Ports 3000-3999, 5000-5999):
#   api.clientvault.fr    → 5000
#   clientvault.fr        → 3100
#   www.clientvault.fr    → 3100 (redirect)
#   mobile.clientvault.fr → 3200
#
# =============================================================================
# Architecture Notes
# =============================================================================
#
# Single VPS hosts both environments with:
# - Docker Compose for orchestration
# - Caddy reverse proxy for hostname-based routing
# - Separate PostgreSQL databases (cluo_staging, cluo_production)
# - Separate Redis instances
# - Separate S3 buckets for assets
#
# All traffic through Cloudflare:
# - SSL/TLS termination at Cloudflare edge
# - DDoS protection
# - Web Application Firewall (WAF)

