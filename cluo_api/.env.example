# CLUO API Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# Environment
# =============================================================================
# Options: development, staging, production
CLUO_ENVIRONMENT=development

# =============================================================================
# Server Configuration
# =============================================================================
CLUO_SERVER_HOST=0.0.0.0
CLUO_SERVER_PORT=8080

# CORS allowed origins — comma-separated list of origins permitted to make
# credentialed requests. Wails desktop production builds use "wails://wails";
# Wails dev mode uses "http://localhost:34115"; SvelteKit dev uses
# "http://localhost:5173". Default when unset: http://localhost:5173
# CLUO_CORS_ORIGIN=http://localhost:5173
CLUO_SERVER_READ_TIMEOUT=15s
CLUO_SERVER_WRITE_TIMEOUT=15s
CLUO_SERVER_IDLE_TIMEOUT=60s
CLUO_SERVER_SHUTDOWN_TIMEOUT=30s

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================
CLUO_DB_HOST=localhost
CLUO_DB_PORT=5432
CLUO_DB_NAME=cluo
CLUO_DB_USER=cluo
CLUO_DB_PASSWORD=your_database_password
CLUO_DB_SSL_MODE=disable
CLUO_DB_MAX_OPEN_CONNS=25
CLUO_DB_MAX_IDLE_CONNS=5
CLUO_DB_CONN_MAX_LIFETIME=5m
CLUO_DB_CONN_MAX_IDLE_TIME=1m

# =============================================================================
# Redis Configuration
# =============================================================================
CLUO_REDIS_HOST=localhost
CLUO_REDIS_PORT=6379
CLUO_REDIS_PASSWORD=
CLUO_REDIS_DB=0

# =============================================================================
# HashiCorp Vault Configuration
# =============================================================================
VAULT_ADDR=http://localhost:8200
# For development only - use AppRole in production
VAULT_TOKEN=your_vault_token
CLUO_VAULT_MOUNT_PATH=secret

# For production (AppRole authentication)
# VAULT_APPROLE_ROLE_ID=your_role_id
# VAULT_APPROLE_SECRET_ID=your_secret_id

# =============================================================================
# AWS S3 Configuration
# =============================================================================
AWS_REGION=us-east-1
CLUO_S3_BUCKET_NAME=cluo-media
CLUO_S3_BASE_URL=
# Optional: Use explicit credentials (otherwise uses IAM role or default chain)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# =============================================================================
# Observability Configuration
# =============================================================================
# Logging
# Options: debug, info, warn, error
CLUO_LOG_LEVEL=debug
# Options: json, text, dev
CLUO_LOG_STYLE=dev

# Metrics (Prometheus)
CLUO_METRICS_ENABLED=true
CLUO_METRICS_PATH=/metrics

# Tracing (OpenTelemetry)
CLUO_TRACING_ENABLED=false
# OTLP gRPC endpoint (e.g., localhost:4317 for local Jaeger/Tempo)
CLUO_TRACING_ENDPOINT=
# Sample rate: 0.0 to 1.0 (1.0 = sample all traces)
CLUO_TRACING_SAMPLER=1.0

# Service identification
CLUO_SERVICE_NAME=cluo-api
CLUO_SERVICE_VERSION=0.1.0

# =============================================================================
# AI Services Configuration
# =============================================================================

# Ollama (Local LLM)
CLUO_AI_OLLAMA_ENABLED=true
CLUO_AI_OLLAMA_BASE_URL=http://localhost:11434
CLUO_AI_OLLAMA_MODEL=llama3.2
CLUO_AI_OLLAMA_TIMEOUT=30s
CLUO_AI_OLLAMA_MAX_INPUT_LEN=10000

# Whisper (Local Speech-to-Text)
CLUO_AI_WHISPER_ENABLED=true
CLUO_AI_WHISPER_BINARY=/usr/local/bin/whisper
CLUO_AI_WHISPER_MODEL_PATH=/models/whisper
CLUO_AI_WHISPER_MODEL=base
CLUO_AI_WHISPER_TIMEOUT=10m
CLUO_AI_WHISPER_DELETE_AUDIO=true

# Transcription Worker
CLUO_AI_WORKER_CONCURRENCY=2
CLUO_AI_WORKER_QUEUE_SIZE=100
CLUO_AI_WORKER_RETRY_ATTEMPTS=3
CLUO_AI_WORKER_RETRY_DELAY=30s
