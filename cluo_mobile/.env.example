# Backend API URL
VITE_API_URL=https://api.yourdomain.com

# Enable mock mode for local development (uses simulated data)
# Set to "true" to use mock data, "false" or remove to use real API
VITE_MOCK_MODE=true

# When set, skips authentication and injects a local mock user.
# Useful when running `pnpm dev` without a backend.
# Accepted values: admin | investigator | viewer  (leave empty to disable)
#
# Example:
#   VITE_MOCK_USER_ROLE=investigator
VITE_MOCK_USER_ROLE=
