# =============================================================================
# Cluo Desktop — Frontend Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# Vite only exposes variables prefixed with VITE_ to the frontend bundle.
# =============================================================================

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------

# Base URL of the Cluo API the desktop app will talk to.
# Omit the trailing slash.
#
# Options:
#   Local dev API (docker compose up):  http://localhost:8080
#   Staging API (recommended for dev):  https://staging-api.clientvault.fr
#   Production VPS (behind Caddy):      https://<prod-api-domain>
#
# Note: when pointing at a remote environment, the API's CORS config must
# allow the origin used by Wails — typically http://localhost:34115 in dev
# mode and wails:// in a production build.
VITE_API_BASE_URL=https://staging-api.clientvault.fr

# -----------------------------------------------------------------------------
# Local dev — mock user
# -----------------------------------------------------------------------------

# When set, skips authentication entirely and injects a local mock user.
# Useful when running `pnpm run dev` without a backend.
# Accepted values: admin | investigator | viewer  (leave empty to disable)
#
# Example:
#   VITE_MOCK_USER_ROLE=admin
VITE_MOCK_USER_ROLE=
